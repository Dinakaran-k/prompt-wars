datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model CookingPlan {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  schedule      String
  people        Int
  diet          String
  budget        Float
  currency      String
  generatedPlan String
}
